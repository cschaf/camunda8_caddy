# docs
docs/superpowers/
docs/specs/
# TLS certificates (never commit private keys)
certs/

# Backup data (generated by scripts/backup.sh and scripts/backup.ps1)
backups/

# Credentials (never commit real secrets)
# .env is part of the repo: it only contains non-secret configuration
# (image versions, HOST, STAGE, TLS paths, etc.). All secrets live in the
# gitignored .env-credentials file (next to the committed
# .env-credentials.example template).
.env-credentials
.env-credentials.local
.env-credentials.*.local
connector-secrets.txt

# Claude Code
.claude/
.playwright-mcp/

# Runtime-generated (use Caddyfile.example as template)
Caddyfile

# Optimize config with secrets (generated from .env)
.optimize/environment-config.yaml

# Console config (rendered from template by start scripts)
.console/application.yaml

# IDE / editor
.vscode/
.idea/
*.iml

# HAR logs (browser traffic recordings)
*.har

# Test artifacts and reports
tests/
playwright-report/
test-results/
*.log

# Monitor logs (generated by scripts/monitor.sh and scripts/monitor.ps1)
monitor.log
monitor.log.*

# Deployment package output (generated by scripts/build_deployment_package.ps1)
build/

# OS
.DS_Store
Thumbs.db

# Local development notes
AGENT.md
CLAUDE.md
.worktrees/
