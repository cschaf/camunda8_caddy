# Add secrets per line in the format NAME=VALUE
# WARNING: do not commit changes to this file — use connector-secrets.txt for local overrides

# Camunda 8.9 connector secrets are resolved with the prefix configured in
# .connectors/application.yaml:
#
#   camunda.connector.secret-provider.environment.prefix: CONNECTORS_SECRET
#
# A BPMN connector field using {{secrets.OPENAI_API_KEY}} therefore resolves
# CONNECTORS_SECRET_OPENAI_API_KEY from this env file.

## Agentic AI / LLM providers ##
# Uncomment only the provider credentials you actually use.

# OpenAI
# CONNECTORS_SECRET_OPENAI_API_KEY=sk-...

# Anthropic
# CONNECTORS_SECRET_ANTHROPIC_API_KEY=sk-ant-...

# Azure OpenAI
# CONNECTORS_SECRET_AZURE_OPENAI_API_KEY=...
# CONNECTORS_SECRET_AZURE_OPENAI_CLIENT_SECRET=...

# Amazon Bedrock
# CONNECTORS_SECRET_AWS_ACCESS_KEY_ID=...
# CONNECTORS_SECRET_AWS_SECRET_ACCESS_KEY=...
# CONNECTORS_SECRET_AWS_SESSION_TOKEN=...

# Google Vertex AI service account JSON.
# Keep this on one line when used as an environment variable.
# CONNECTORS_SECRET_GOOGLE_VERTEX_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# MCP Client connector authentication for remote MCP servers.
# CONNECTORS_SECRET_MCP_CLIENT_SECRET=...
# CONNECTORS_SECRET_MCP_API_KEY=...
# CONNECTORS_SECRET_MCP_CUSTOM_HEADER=...
