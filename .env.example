# Requires PowerShell 7+ on Windows (https://github.com/PowerShell/PowerShell/releases)
# Linux/macOS: use bash scripts instead
#
# This file documents the non-credential environment parameters. All secrets
# (OIDC client secrets, database passwords, Keycloak admin, Pusher keys,
# registry credentials, license key, etc.) live in .env-credentials. Copy
# .env-credentials.example to .env-credentials and fill in real values, or
# run scripts/generate-secrets.{sh,ps1} to populate it with strong random
# secrets. Keep advanced overrides commented unless you intentionally need
# a non-default topology.

## Image versions ##
# renovate: datasource=docker depName=camunda/camunda
CAMUNDA_VERSION=8.9.6
# renovate: datasource=docker depName=camunda/connectors-bundle
CAMUNDA_CONNECTORS_VERSION=8.9.5
# renovate: datasource=docker depName=camunda/identity
CAMUNDA_IDENTITY_VERSION=8.9.4
# renovate: datasource=docker depName=camunda/operate
CAMUNDA_OPERATE_VERSION=8.9.6
# renovate: datasource=docker depName=camunda/tasklist
CAMUNDA_TASKLIST_VERSION=8.9.6
# renovate: datasource=docker depName=camunda/optimize
CAMUNDA_OPTIMIZE_VERSION=8.9.6
# renovate: datasource=docker depName=camunda/web-modeler-restapi
CAMUNDA_WEB_MODELER_VERSION=8.9.4
# renovate: datasource=docker depName=camunda/console
CAMUNDA_CONSOLE_VERSION=8.9.44
# renovate: datasource=docker depName=elasticsearch
ELASTIC_VERSION=8.19.11
KEYCLOAK_SERVER_VERSION=26.3.2
# renovate: datasource=docker depName=axllent/mailpit
MAILPIT_VERSION=v1.21.8
POSTGRES_VERSION=15-alpine3.22

## Network Configuration ##
# HOST: Used for browser/external access URLs (e.g., redirect URIs, UI links)
HOST=camunda.dev.local
# KEYCLOAK_HOST is the internal Docker DNS name used by services.
KEYCLOAK_HOST=keycloak
# Advanced Compose overrides:
# COMPOSE_PROJECT_NAME=camundacomposenvl
# COMPOSE_FILE=docker-compose.yaml
# ENV_FILE=.env

## Stage / Environment Label ##
STAGE=PROD
# Optional: override the label shown on the dashboard, page title, and
# Camunda Console "tags" without changing the resource profile loaded
# from STAGE. If unset, the displayed label falls back to STAGE.
# DISPLAY_STAGE=TEST
BANNER_DARKMODE=/banner-darkmode.png
BANNER_LIGHTMODE=/banner-lightmode.svg

## Camunda Private Registry Endpoint ##
# Public Harbor URL. Username and password live in .env-credentials.
CAMUNDA_REGISTRY_URL=https://registry.camunda.cloud

## Camunda License ##
# The license key lives in .env-credentials (gitignored). Multi-line keys
# must use single quotes so docker compose and the bash start script keep
# the value as one variable.

## Backup Configuration ##
# Increase (e.g. 300) for loaded Zeebe instances to avoid SIGKILL during cold backup.
BACKUP_STOP_TIMEOUT=180
# Elasticsearch endpoint used by backup/restore scripts from the host.
ES_HOST=localhost
ES_PORT=9200
# Health-check timeout in seconds during restore startup.
RESTORE_HEALTH_TIMEOUT=300
# Restore/drill override for the Elasticsearch snapshot volume name.
# ES_BACKUP_VOLUME=elastic-backup
# Base directory for backups (defaults to backups/ in the project root).
# BACKUP_BASE_DIR=/path/to/backups

## Restore Drill Configuration (Optional) ##
# Isolated restore-drill Compose project and host/port overrides.
# DRILL_PORT_OFFSET=10000
# DRILL_HOST=drill.localhost
# DRILL_PROJECT_NAME=camunda-restoredrill
# DRILL_KNOWN_PROJECT_ID=

## TLS Certificates (Optional) ##
# Path to your TLS certificate files. If not set, Caddy generates self-signed certs.
# FULLCHAIN_PEM=/path/to/fullchain.pem
# PRIVATEKEY_PEM=/path/to/privkey.pem

## OIDC Client IDs ##
# Client IDs are non-secret identifiers; the matching *_CLIENT_SECRET values
# live in .env-credentials.
ORCHESTRATION_CLIENT_ID=orchestration
CONNECTORS_CLIENT_ID=connectors

## Web Modeler Mail (Optional) ##
WEBMODELER_MAIL_FROM_ADDRESS=noreply@camunda.example.com

## Feature Flags ##
# Set to 'true' to enable resource based authorizations for users and groups
# This can be used to limit access for users or groups to view/update specific
# processes and decisions in Operate and Tasklist
RESOURCE_AUTHORIZATIONS_ENABLED=true

## Monitor Configuration (Optional) ##
# Override defaults used by scripts/monitor.sh and scripts/monitor.ps1.
# MONITOR_LOG_FILE=monitor.log
# MONITOR_LOG_MAX_SIZE=10485760
# MONITOR_LOG_MAX_ARCHIVES=5

## Document Store Configuration (Optional) ##
# Uncomment and configure if using external document storage
# DOCUMENT_DEFAULT_STORE_ID=...
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=...
# DOCUMENT_STORE_AWS_BUCKET=...
# DOCUMENT_STORE_AWS_BUCKET_PATH=...
# DOCUMENT_STORE_AWS_CLASS=...
