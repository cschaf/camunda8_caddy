# Caddyfile for Camunda Compose NVL - Reverse Proxy
# Ready for production when paired with production TLS certificates and hardened environment secrets

# Custom TLS certificates (optional):
# If FULLCHAIN_PEM and PRIVATEKEY_PEM are set in .env, the setup-host scripts
# inject a "tls <cert> <key>" directive for each site block below.
# If not set, Caddy automatically generates self-signed certificates for all sites.

# Dashboard (landing page)
camunda.dev.local {
    root * /srv/dashboard
    file_server
    templates
}

# Keycloak
keycloak.camunda.dev.local {
    # Health check endpoint for dashboard status LEDs
    handle /health {
        header Access-Control-Allow-Origin "*"
        reverse_proxy keycloak:18080 {
            header_down -Cross-Origin-Resource-Policy
            header_down -Cross-Origin-Embedder-Policy
        }
    }
    # Intercept the OIDC check_session_iframe endpoint and return a mock that always
    # reports "unchanged". Chrome 120+ blocks cross-origin JavaScript cookie access
    # in iframes, so the real iframe fails to read KEYCLOAK_SESSION, returns "error",
    # triggers prompt=none, and Keycloak returns login_required — clearing the token.
    @check-session-iframe {
        path /auth/realms/camunda-platform/protocol/openid-connect/login-status-iframe.html
    }
    handle @check-session-iframe {
        header Content-Type "text/html; charset=utf-8"
        respond `<!DOCTYPE html><html><body><script>window.addEventListener("message",function(e){if(!e.data||e.data==="init")return;e.source.postMessage("unchanged",e.origin);});</script></body></html>` 200
    }
    reverse_proxy keycloak:18080
}

# Identity
identity.camunda.dev.local {
    # Health check endpoint for dashboard status LEDs
    handle /health {
        header Access-Control-Allow-Origin "*"
        reverse_proxy identity:8084 {
            header_down -Cross-Origin-Resource-Policy
            header_down -Cross-Origin-Embedder-Policy
        }
    }
    @options {
        method OPTIONS
    }
    handle @options {
        respond "OK" 200
        header Access-Control-Allow-Origin "*"
        header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        header Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, Accept, Origin"
        header Access-Control-Max-Age "3600"
    }

    # Fonts are fetched with sec-fetch-mode: cors by the browser (CSS @font-face),
    # but Identity's Spring Security rejects them because it doesn't recognise
    # https://identity.camunda.dev.local as an allowed CORS origin. Strip the Origin header
    # so Spring Security serves them as plain static files.
    @static {
        path /static/*
    }
    handle @static {
        reverse_proxy identity:8084 {
            header_up -Origin
        }
    }

    reverse_proxy identity:8084
}

# Console
console.camunda.dev.local {
    # Health check endpoint for dashboard status LEDs
    handle /health {
        header Access-Control-Allow-Origin "*"
        reverse_proxy console:8080 {
            header_down -Cross-Origin-Resource-Policy
            header_down -Cross-Origin-Embedder-Policy
        }
    }
    # Console 8.9 ships CSS with unresolved IBM Plex font URLs. Without this,
    # the Express SPA fallback returns index.html for those .woff2 requests,
    # which browsers then try to parse as fonts.
    @console-fonts {
        path_regexp ^/assets/~@ibm/plex/.+\.woff2$
    }
    handle @console-fonts {
        respond "Console font asset not bundled" 404
    }
    reverse_proxy console:8080
}

# Optimize
optimize.camunda.dev.local {
    # Health check endpoint for dashboard status LEDs
    handle /health {
        header Access-Control-Allow-Origin "*"
        reverse_proxy optimize:8090 {
            header_down -Cross-Origin-Resource-Policy
            header_down -Cross-Origin-Embedder-Policy
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-Host optimize.camunda.dev.local
        }
    }
    reverse_proxy optimize:8090 {
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-Host optimize.camunda.dev.local
    }
}

# Orchestration (Operate/Tasklist)
orchestration.camunda.dev.local {
    # Health check endpoint for dashboard status LEDs
    handle /health {
        header Access-Control-Allow-Origin "*"
        reverse_proxy orchestration:8080 {
            header_down -Cross-Origin-Resource-Policy
            header_down -Cross-Origin-Embedder-Policy
        }
    }
    @options {
        method OPTIONS
    }
    handle @options {
        respond "OK" 200
        header Access-Control-Allow-Origin "*"
        header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        header Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, Accept, Origin"
        header Access-Control-Max-Age "3600"
    }

    @static {
        path /static/*
    }
    handle @static {
        reverse_proxy orchestration:8080 {
            header_up -Origin
        }
    }

    reverse_proxy orchestration:8080 {
        # Camunda 8.9 emits draft/experimental feature tokens that Chrome logs
        # as unrecognized Permissions-Policy warnings in Tasklist/Operate.
        header_down -Permissions-Policy
    }
}

# Zeebe gRPC Gateway
zeebe.localhost {
    reverse_proxy h2c://orchestration:26500 {
        flush_interval -1
    }
}

# Web Modeler
webmodeler.camunda.dev.local {
    # Health check endpoint for dashboard status LEDs
    handle /health {
        header Access-Control-Allow-Origin "*"
        reverse_proxy web-modeler-restapi:8081 {
            header_down -Cross-Origin-Resource-Policy
            header_down -Cross-Origin-Embedder-Policy
        }
    }
    # Pusher WebSocket connections (real-time collaboration)
    handle /app/* {
        reverse_proxy web-modeler-websockets:8060
    }
    reverse_proxy web-modeler-restapi:8081
}
