# Template for .env-credentials. Copy this file to .env-credentials and fill
# in the values for your deployment, or run `scripts/generate-secrets.{sh,ps1}`
# to populate it with strong random secrets.
#
# This file is loaded by Docker Compose (via `--env-file .env-credentials` in
# the start scripts, and via `env_file:` on credential-relevant services in
# docker-compose.yaml) and by every helper script that needs a credential.
# It is gitignored. Never commit a populated copy.

## Camunda Private Registry (Optional) ##
# Used by scripts/registry-info.{ps1,sh} to query Camunda's Harbor registry.
# Credentials are issued by Camunda to enterprise customers (robot accounts).
# CAMUNDA_REGISTRY_USERNAME=
# CAMUNDA_REGISTRY_PASSWORD=

## OIDC Client Configuration ##
# Orchestration (Zeebe Gateway + Operate + Tasklist)
ORCHESTRATION_CLIENT_ID=orchestration
ORCHESTRATION_CLIENT_SECRET=secret

# Connectors
CONNECTORS_CLIENT_ID=connectors
CONNECTORS_CLIENT_SECRET=demo-connectors-secret

# Console
CONSOLE_CLIENT_SECRET=demo-console-secret

# Optimize
OPTIMIZE_CLIENT_SECRET=demo-optimize-secret

# Identity service OIDC client secret
CAMUNDA_IDENTITY_CLIENT_SECRET=demo-identity-secret

## Elasticsearch Configuration ##
ELASTIC_PASSWORD=demo-elastic-password

## Database Configuration ##
# Identity/Keycloak PostgreSQL Database
POSTGRES_DB=bitnami_keycloak
POSTGRES_USER=bn_keycloak
POSTGRES_PASSWORD=demo-postgres-password

# Camunda Core PostgreSQL Database
CAMUNDA_DB_NAME=camunda
CAMUNDA_DB_USER=camunda
CAMUNDA_DB_PASSWORD=demo-camunda-password

# Web Modeler PostgreSQL Database
WEBMODELER_DB_NAME=web-modeler-db
WEBMODELER_DB_USER=web-modeler-db-user
WEBMODELER_DB_PASSWORD=demo-webmodeler-password

## Keycloak Admin Credentials ##
# WARNING: Change these for production deployments!
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

## Web Modeler Configuration ##
# Pusher configuration for WebSocket communication
WEBMODELER_PUSHER_APP_ID=web-modeler-app
WEBMODELER_PUSHER_KEY=web-modeler-app-key
WEBMODELER_PUSHER_SECRET=web-modeler-app-secret

## Camunda License (Optional for non-production, required for production use) ##
# Keep the real key only in .env-credentials. For multi-line keys, use
# single quotes so docker compose and the bash start script keep the value
# as one variable.
# CAMUNDA_LICENSE_KEY='--------------- BEGIN CAMUNDA LICENSE KEY ---------------
# ... complete key from Camunda ...
# --------------- END CAMUNDA LICENSE KEY ---------------'

## Demo User ##
# WARNING: Change for production — generated by scripts/generate-secrets.sh
DEMO_USER_PASSWORD=demo
