es:
  settings:
    index:
      number_of_shards: 1
      number_of_replicas: 0
  security:
    username: elastic
    password: "ELASTIC_PASSWORD_PLACEHOLDER"
zeebe:
  enabled: true
  name: zeebe-record
  partitionCount: 1
enterprise: false
security:
  auth:
    cookie:
      same-site:
        enabled: false
ui:
  logoutHidden: true
historyCleanup:
  cronTrigger: 0 1 * * *
  ttl: P365D
  processDataCleanup:
    enabled: true
